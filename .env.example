BOT_TOKEN=telegram_bot_token_from_botfather
BOT_USERNAME=your_bot_username
WEBAPP_URL=https://your-domain.example
PORT=3000
ADMIN_TOKEN=change_me_admin_token
# Only for local browser testing outside Telegram. Do not enable on production.
ALLOW_INSECURE_DEV_AUTH=false

SUBGRAM_API_KEY=subgram_bot_api_key
SUBGRAM_API_BASE=https://api.subgram.org
SUBGRAM_ACTION=task
SUBGRAM_MAX_SPONSORS=10
SUBGRAM_REWARD=0.25
MIN_WITHDRAW_AMOUNT=50
REFERRAL_PERCENT=10
FAKE_ONLINE_ENABLED=true
FAKE_ONLINE_MIN=18
FAKE_ONLINE_MAX=64

DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_SSL=true
